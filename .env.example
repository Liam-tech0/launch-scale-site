# YouTube Data API v3
# 1. https://console.cloud.google.com → Nouveau projet
# 2. Bibliothèque → "YouTube Data API v3" → Activer
# 3. Identifiants → Créer une clé API
YOUTUBE_API_KEY=

# ID de ta chaîne YouTube (format: UCxxxxxxxxxxxxxxxxxxxxxxxx)
# Chaîne → À propos → Partager → Copier l'ID de la chaîne
YOUTUBE_CHANNEL_ID=

# URL complète de ta chaîne (ex: https://youtube.com/@launch-and-scale)
NEXT_PUBLIC_YOUTUBE_CHANNEL_URL=
